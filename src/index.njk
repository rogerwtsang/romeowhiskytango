<section id="contact" style="background: #1a1a1a;">
    <div class="section-header">
        <h2 class="section-title">Contact</h2>
        <p class="section-subtitle">Let's start a conversation</p>
    </div>

    <div class="contact-container">
        <div class="contact-cards">
            <div class="contact-card">
                <div class="contact-card-icon">📧</div>
                <h3>Email</h3>
                <p>For longer conversations</p>
                <a href="mailto:your.email@example.com" class="contact-link">your.email@example.com</a>
            </div>

            <div class="contact-card">
                <div class="contact-card-icon">💼</div>
                <h3>LinkedIn</h3>
                <p>Professional networking</p>
                <a href="#" class="contact-link">Connect with me</a>
            </div>

            <div class="contact-card">
                <div class="contact-card-icon">💻</div>
                <h3>GitHub</h3>
                <p>Check out my code</p>
                <a href="#" class="contact-link">github.com/yourusername</a>
            </div>
        </div>

        <div class="chat-form">
            <h3>Or send me a quick message</h3>
            <p>I'll get back to you within 24 hours</p>

            <form id="contactForm" name="contact" method="POST" data-netlify="true">
                <div class="progress-dots">
                    <span class="progress-dot active"></span>
                    <span class="progress-dot"></span>
                    <span class="progress-dot"></span>
                </div>

                <div class="form-step active" data-step="1">
                    <label>👋 What's your name?</label>
                    <input type="text" name="name" placeholder="Your name" required>
                </div>

                <div class="form-step" data-step="2">
                    <label>📧 How can I reach you?</label>
                    <input type="email" name="email" placeholder="your.email@example.com" required>
                </div>

                <div class="form-step" data-step="3">
                    <label>💬 What's on your mind?</label>
                    <textarea name="message" placeholder="Tell me about your project, question, or just say hi..." required></textarea>
                </div>

                <div class="form-buttons">
                    <button type="button" class="form-btn back-btn" id="backBtn" style="display: none;">← Back</button>
                    <button type="button" class="form-btn next-btn" id="nextBtn">Next →</button>
                    <button type="submit" class="form-btn next-btn" id="submitBtn" style="display: none;">Send Message ✓</button>
                </div>
            </form>

            <div id="successMessage" class="success-message" style="display: none;">
                <div class="icon">✓</div>
                <h3>Message Sent!</h3>
                <p>Thanks for reaching out. I'll get back to you soon.</p>
            </div>
        </div>
    </div>
</section>
